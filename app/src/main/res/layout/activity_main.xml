<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1A1A2E"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bitcoin Widget"
        android:textSize="26sp"
        android:textColor="#FFFFFFFF"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="32dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:padding="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#33FFFFFF"
            android:padding="12dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRICE"
                android:textSize="11sp"
                android:textColor="#99FFFFFF"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/activity_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ --,---"
                android:textSize="20sp"
                android:textColor="#FFFFFFFF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#33FFFFFF"
            android:padding="12dp"
            android:layout_marginHorizontal="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BLOCK"
                android:textSize="11sp"
                android:textColor="#99FFFFFF"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/activity_block"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---,---"
                android:textSize="20sp"
                android:textColor="#FFFFFFFF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#33FFFFFF"
            android:padding="12dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HASHRATE"
                android:textSize="11sp"
                android:textColor="#99FFFFFF"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/activity_hashrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--- EH/s"
                android:textSize="20sp"
                android:textColor="#FFFFFFFF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/activity_last_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last updated: --"
        android:textSize="12sp"
        android:textColor="#66FFFFFF"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/btn_refresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REFRESH"
        android:textColor="#FF1A1A2E"
        android:backgroundTint="#FFFFD700"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="32dp" />

</LinearLayout>
