<!-- 4x2 Bitcoin Widget Layout – Material 3 / Material You -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Top row: TextClock (digital clock, HH:mm) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/metric_card_bg"
        android:padding="12dp">

        <TextClock
            android:id="@+id/clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format24Hour="HH:mm"
            android:format12Hour="hh:mm a"
            android:textSize="48sp"
            android:textColor="?android:attr/textColorPrimary"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingExtra="0sp" />

    </LinearLayout>

    <!-- Bottom row: 3 metric cards in a grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:weightSum="3">

        <!-- Bitcoin Price -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/metric_card_bg"
            android:padding="8dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/label_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRICE"
                android:textSize="10sp"
                android:textColor="?android:attr/textColorSecondary"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/value_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ --,---"
                android:textSize="18sp"
                android:textColor="?android:attr/textColorPrimary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Block Number -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/metric_card_bg"
            android:padding="8dp"
            android:layout_marginHorizontal="2dp">

            <TextView
                android:id="@+id/label_block"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BLOCK"
                android:textSize="10sp"
                android:textColor="?android:attr/textColorSecondary"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/value_block"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---,---"
                android:textSize="18sp"
                android:textColor="?android:attr/textColorPrimary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Network Hashrate -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/metric_card_bg"
            android:padding="8dp"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/label_hashrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HASHRATE"
                android:textSize="10sp"
                android:textColor="?android:attr/textColorSecondary"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/value_hashrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--- EH/s"
                android:textSize="18sp"
                android:textColor="?android:attr/textColorPrimary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
